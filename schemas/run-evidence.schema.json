{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/M-sea-art/codex-efficiency-auditor/schemas/run-evidence.schema.json",
  "title": "Codexcavator Strict Run Evidence v0.3",
  "type": "object",
  "required": [
    "schema_version",
    "source_format",
    "source_sha256",
    "redaction",
    "parse_status",
    "invalid_line_count",
    "unknown_event_types",
    "session",
    "execution_contexts",
    "metrics",
    "tool_usage"
  ],
  "properties": {
    "schema_version": { "const": "0.3" },
    "source_format": { "const": "codex_jsonl" },
    "source_sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "redaction": { "const": "strict_metadata_v1" },
    "parse_status": { "type": "string", "enum": ["PASS", "PARTIAL"] },
    "invalid_line_count": { "type": "integer", "minimum": 0 },
    "unknown_event_types": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "session": {
      "type": "object",
      "required": ["session_id_hash", "cli_version", "originator", "turn_count"],
      "properties": {
        "session_id_hash": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
          ]
        },
        "cli_version": { "type": ["string", "null"], "minLength": 1 },
        "originator": { "type": ["string", "null"], "minLength": 1 },
        "turn_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "execution_contexts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["turn_id_hash", "collaboration_mode", "approval_policy", "sandbox_mode", "multi_agent_mode"],
        "properties": {
          "turn_id_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "collaboration_mode": { "type": ["string", "null"] },
          "approval_policy": { "type": ["string", "null"] },
          "sandbox_mode": { "type": ["string", "null"] },
          "multi_agent_mode": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "turns_started",
        "turns_completed",
        "turns_aborted",
        "total_duration_ms",
        "average_time_to_first_token_ms",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "reasoning_output_tokens",
        "total_tokens",
        "tool_calls",
        "failed_tool_calls",
        "mcp_calls",
        "failed_mcp_calls",
        "web_searches",
        "patch_calls",
        "failed_patch_calls"
      ],
      "properties": {
        "turns_started": { "$ref": "#/$defs/count" },
        "turns_completed": { "$ref": "#/$defs/count" },
        "turns_aborted": { "$ref": "#/$defs/count" },
        "total_duration_ms": { "$ref": "#/$defs/count" },
        "average_time_to_first_token_ms": { "$ref": "#/$defs/count" },
        "input_tokens": { "$ref": "#/$defs/count" },
        "cached_input_tokens": { "$ref": "#/$defs/count" },
        "output_tokens": { "$ref": "#/$defs/count" },
        "reasoning_output_tokens": { "$ref": "#/$defs/count" },
        "total_tokens": { "$ref": "#/$defs/count" },
        "tool_calls": { "$ref": "#/$defs/count" },
        "failed_tool_calls": { "$ref": "#/$defs/count" },
        "mcp_calls": { "$ref": "#/$defs/count" },
        "failed_mcp_calls": { "$ref": "#/$defs/count" },
        "web_searches": { "$ref": "#/$defs/count" },
        "patch_calls": { "$ref": "#/$defs/count" },
        "failed_patch_calls": { "$ref": "#/$defs/count" }
      },
      "additionalProperties": false
    },
    "tool_usage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "count", "failures"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "count": { "$ref": "#/$defs/count" },
          "failures": { "$ref": "#/$defs/count" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
