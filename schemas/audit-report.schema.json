{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/M-sea-art/codex-efficiency-auditor/schemas/audit-report.schema.json",
  "title": "Codexcavator Capability Audit",
  "type": "object",
  "required": ["audit_id", "target_type", "goal", "mutation_status", "capabilities", "upgrades"],
  "properties": {
    "audit_id": { "type": "string", "minLength": 1 },
    "target_type": {
      "type": "string",
      "enum": ["thread", "repo", "worktree", "pr", "agent_run", "transcript"]
    },
    "goal": { "type": "string", "minLength": 1 },
    "mutation_status": {
      "type": "string",
      "enum": ["NO_FILES_MODIFIED_BY_AUDIT", "MUTATION_DETECTED", "UNKNOWN"]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "relevance", "availability", "discovered", "usage", "impact", "evidence"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "relevance": { "type": "string", "enum": ["required", "useful", "irrelevant"] },
          "availability": { "type": "string", "enum": ["available", "unavailable", "unknown"] },
          "discovered": { "type": "boolean" },
          "usage": { "type": "string", "enum": ["used", "unused", "misused", "not_applicable"] },
          "impact": { "type": "integer", "minimum": 1, "maximum": 5 },
          "evidence": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "upgrades": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["capability", "gap", "action", "expected_gain", "verification"],
        "properties": {
          "capability": { "type": "string", "minLength": 1 },
          "gap": {
            "type": "string",
            "enum": ["UNAVAILABLE", "UNDISCOVERED", "UNUSED", "MISUSED", "UNVERIFIED"]
          },
          "action": { "type": "string", "minLength": 1 },
          "expected_gain": { "type": "string", "minLength": 1 },
          "verification": { "type": "string", "minLength": 1 },
          "human_gate": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
